{
  "version": 1,
  "kind": "animation_cycles",
  "description": "Canonical animation cycle definitions for sprites. Each cycle = ordered list of (frame_idx, duration_ms, key_pose). instantiate_animation_cycle(slug) creates frames with these durations and a tag covering them. Direction defaults to forward; cycles with anticipation/recovery can use ping-pong.",
  "principles_reference": "See presets/reference/animation_principles.json for the 12 animation principles applied to pixel art (squash/stretch, anticipation, follow-through, etc).",
  "cycles": {
    "idle_breathe_2f": {
      "name": "Idle breathe (2 frames)",
      "description": "Minimal NES/GB-era idle. 2 frames alternating with 1px chest rise.",
      "frame_count": 2,
      "durations_ms": [500, 500],
      "key_poses": ["chest_low", "chest_high_1px"],
      "loop": "ping-pong-or-forward",
      "tag_role": "idle",
      "recommended_for": ["npc", "minor_enemy", "background_character"]
    },
    "idle_breathe_4f": {
      "name": "Idle breathe (4 frames)",
      "description": "Smoother SNES-era breath cycle.",
      "frame_count": 4,
      "durations_ms": [200, 200, 200, 200],
      "key_poses": ["chest_low", "rising", "chest_high_1px", "falling"],
      "loop": "forward",
      "tag_role": "idle",
      "recommended_for": ["hero", "important_npc"]
    },
    "idle_sway_4f": {
      "name": "Idle sway (4 frames)",
